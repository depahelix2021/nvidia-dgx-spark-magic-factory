#!/usr/bin/env python3
# ptr b0010001

import json, os, signal, socket, subprocess, sys, time, urllib.request

DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
REG = os.path.join(DIR, "services.json")

KNOWN_SERVICES = {
    "harness":  {"port": 7711, "pid_file": os.path.join(DIR, ".pid"),              "label": "Magic Factory"},
    "chat":     {"port": 7722, "pid_file": os.path.join(DIR, "chat", ".chat.pid"), "label": "Magic Factory Chat"},
    "open-webui": {"port": 7733, "pid_file": None,                                 "label": "Open WebUI",
                   "docker": "open-webui"},
}

# ptr b0010003

def _load():
    if os.path.exists(REG):
        with open(REG) as f:
            return json.load(f)
    return {}

def _save(data):
    with open(REG, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")

def _pid_alive(pid):
    try:
        os.kill(pid, 0)
        return True
    except PermissionError:
        return True
    except (OSError, TypeError):
        return False

def _port_listening(port):
    with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
        s.settimeout(0.3)
        return s.connect_ex(("127.0.0.1", int(port))) == 0

def _http_ready(port, timeout=0.8):
    try:
        r = urllib.request.urlopen(f"http://127.0.0.1:{port}/", timeout=timeout)
        return r.status < 500
    except Exception:
        return False

def _read_pid_file(path):
    if path and os.path.isfile(path):
        try:
            return int(open(path).read().strip())
        except (ValueError, OSError):
            pass
    return None

def _docker_running(name):
    try:
        out = subprocess.check_output(
            ["docker", "ps", "--format", "{{.Names}}"],
            stderr=subprocess.DEVNULL, timeout=5
        ).decode()
        for line in out.strip().splitlines():
            if line == name or line.startswith(name.replace("-", "") + "-"):
                return True
    except Exception:
        pass
    return False

# ptr b0010004

def _open_url(url):
    """Open a URL via the freedesktop D-Bus portal.

    Works with snap Firefox under both sudo and non-sudo by asking the
    desktop session (not the snap) to handle the URL.
    """
    gdbus_cmd = [
        "gdbus", "call", "--session",
        "--dest", "org.freedesktop.portal.Desktop",
        "--object-path", "/org/freedesktop/portal/desktop",
        "--method", "org.freedesktop.portal.OpenURI.OpenURI",
        "", url, "{}",
    ]
    sudo_user = os.environ.get("SUDO_USER")
    if sudo_user and os.geteuid() == 0:
        import pwd
        real_uid = str(pwd.getpwnam(sudo_user).pw_uid)
        env_vars = {
            "DBUS_SESSION_BUS_ADDRESS": f"unix:path=/run/user/{real_uid}/bus",
            "XDG_RUNTIME_DIR": f"/run/user/{real_uid}",
        }
        subprocess.Popen(
            ["sudo", "-u", sudo_user] + [f"{k}={v}" for k, v in env_vars.items()] + gdbus_cmd,
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
    else:
        subprocess.Popen(gdbus_cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def cmd_sync():
    reg = _load()

    for name, meta in KNOWN_SERVICES.items():
        port = meta["port"]
        entry = reg.get(name, {})
        entry["label"] = meta["label"]
        entry["port"] = port

        actual_pid = None
        if meta.get("docker"):
            entry["type"] = "docker"
            entry["running"] = _docker_running(meta["docker"]) and _port_listening(port)
            if entry["running"]:
                entry["ready"] = _http_ready(port)
        else:
            entry["type"] = "process"
            actual_pid = _read_pid_file(meta["pid_file"])
            listening = _port_listening(port)

            if actual_pid and _pid_alive(actual_pid) and listening:
                entry["pid"] = actual_pid
                entry["running"] = True
                entry["ready"] = _http_ready(port)
            elif listening:
                try:
                    out = subprocess.check_output(
                        ["lsof", "-ti", f":{port}", "-sTCP:LISTEN"],
                        stderr=subprocess.DEVNULL, timeout=3
                    ).decode().strip()
                    real_pid = int(out.splitlines()[0]) if out else None
                except Exception:
                    real_pid = None
                entry["pid"] = real_pid
                entry["running"] = True
                entry["ready"] = _http_ready(port)
            else:
                entry["pid"] = None
                entry["running"] = False
                entry["ready"] = False

        reg[name] = entry

    for name in list(reg):
        if name not in KNOWN_SERVICES:
            port = reg[name].get("port")
            if port and _port_listening(port):
                reg[name]["running"] = True
                reg[name]["ready"] = _http_ready(port)
            else:
                reg[name]["running"] = False
                reg[name]["ready"] = False

    _save(reg)
    return reg

def cmd_set(name, port, pid=None):
    reg = _load()
    meta = KNOWN_SERVICES.get(name, {})
    reg[name] = {
        "label": meta.get("label", name),
        "port": int(port),
        "pid": int(pid) if pid else None,
        "type": meta.get("type", "docker" if meta.get("docker") else "process"),
        "running": True,
        "ready": False,
    }
    _save(reg)

def cmd_drop(name):
    reg = _load()
    if name in reg:
        reg[name]["running"] = False
        reg[name]["ready"] = False
        reg[name]["pid"] = None
    _save(reg)

def cmd_show():
    reg = cmd_sync()
    for name, info in reg.items():
        status = "ready" if info.get("ready") else ("running" if info.get("running") else "stopped")
        icon = {"ready": "\u26a1", "running": "\u23f3", "stopped": "\u2b1b"}.get(status, " ")
        pid_str = f"  PID {info['pid']}" if info.get("pid") else ""
        print(f"  {icon} {info.get('label', name):20s} :{info['port']}  [{status}]{pid_str}")

def cmd_open():
    reg = cmd_sync()
    opened = 0
    for name, info in reg.items():
        if not info.get("running"):
            continue
        port = info["port"]
        for _ in range(12):
            if _http_ready(port):
                break
            time.sleep(0.5)
        else:
            print(f"  Skipping {info.get('label', name)} — not ready on :{port}")
            continue
        info["ready"] = True
        url = f"http://localhost:{port}"
        print(f"  \u26a1 {info.get('label', name)} — {url}")
        _open_url(url)
        opened += 1
    _save(reg)
    if opened == 0:
        print("\n  No services ready. Start with: bin/start.sh")

# ptr b0010008

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args or args[0] == "show":
        cmd_show()
    elif args[0] == "sync":
        cmd_sync()
        cmd_show()
    elif args[0] == "open":
        cmd_open()
    elif args[0] == "set" and len(args) >= 3:
        cmd_set(args[1], args[2], args[3] if len(args) > 3 else None)
    elif args[0] == "drop" and len(args) >= 2:
        cmd_drop(args[1])
    else:
        print(__doc__)
        sys.exit(1)
