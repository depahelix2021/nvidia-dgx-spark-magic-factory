# Optional — enables Claude-assisted troubleshooting
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model to pull and test (default: qwen3-coder-next)
# Requires Ollama >= 0.15.5 for MoE/SSM models
SPARK_MODEL=qwen3-coder-next

# Open WebUI session secret (generate with: python3 -c "import secrets; print(secrets.token_hex(32))")
WEBUI_SECRET_KEY=replace-with-a-random-hex-string
